# Copy to .env.local for local development (never commit .env.local).
# In Vercel: Project → Settings → Environment Variables (Production + Preview).

# Required for Interactive CV chat
OPENAI_API_KEY=

# Optional: distributed rate limiting (recommended for production)
# Create a free database at https://upstash.com — use REST URL + token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
